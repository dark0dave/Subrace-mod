amends "package://github.com/jdx/hk/releases/download/v1.44.2/hk@1.44.2#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.44.2/hk@1.44.2#/Builtins.pkl"

local message = new Mapping<String, Step> {
  ["check-conventional-commit"] = Builtins.check_conventional_commit
}

local builtin_hooks = new Mapping<String, Step> {
  ["check-case-conflict"] = Builtins.check_case_conflict
  ["check-merge-conflict"] = Builtins.check_merge_conflict
  ["end-of-file-fixer"] = Builtins.newlines
  ["trailing-whitespace"] = Builtins.trailing_whitespace
  ["yamlfmt"] = Builtins.yamlfmt
}

local local_hooks = new Mapping<String, Step> {
  ["check-ie"] {
    glob = List("*.bam","*.baf","*.cre","*.d","*.itm","*.spl","*.sto","*.wav","*.vvc")
    check = ".github/scripts/check-ie.sh {{files}}"
  }
  ["git-check"] {
    check = ".github/scripts/check-git.sh"
    fix = "git add --renormalize ."
  }
  ["weidu-check"] {
    glob = List("*.d","*.tp2","*.tpa","*.tpp","*.tph")
    check = ".github/scripts/check-weidu.sh {{files}}"
  }
  ["version-check"] {
    check = ".github/scripts/check-version.sh"
  }
  ["nix fmt"] {
    fix = "nixfmt flake.nix"
  }
}

hooks {
  ["commit-msg"] {
    steps {
      ...message
    }
  }
  ["pre-commit"] {
    fix = true
    stash = "git"
    steps {
      ...builtin_hooks
      ...local_hooks
    }
  }
}
