	Global("P5_SUBRACE","GLOBAL",21)
THEN
	RESPONSE #100
		SetGlobal("P5_SUBRACE","GLOBAL", 999)
		SetGlobal("Player_5_Change_Subrace","GLOBAL",21)
		ActionOverride(Player5,SetGlobal("SUBRACE","LOCALS",21))
		ActionOverride(Player5,ApplySpellRES("SR_ELYTH",Player5))
END

