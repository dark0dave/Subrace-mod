IF
	Global("Player_1_Change_Subrace","GLOBAL",0)
	Global("P1_SUBRACE","GLOBAL", 0)
THEN
	RESPONSE #100
		SetGlobal("P1_SUBRACE","GLOBAL", 999)
		SetGlobal("Player_1_Change_Subrace","GLOBAL",10)
		ActionOverride(Player1,SetGlobal("SUBRACE", "LOCALS",10))
END

